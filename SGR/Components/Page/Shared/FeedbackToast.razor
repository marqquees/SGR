@if (!string.IsNullOrEmpty(Message))
{
    <div class="toast-container position-fixed bottom-0 start p-2">
        <div class="toast show @(Success ? "bg-success" : "bg-danger") text-white" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi @(Success ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
                    @Message
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Success { get; set; }
    [Parameter] public string? Message { get; set; }
}